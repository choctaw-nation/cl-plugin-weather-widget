{
	"name": "choctaw-nation/choctaw-landing-weather-widget",
	"description": "A plugin that fetches weather data for the Choctaw Landing site.",
	"type": "project",
	"version": "1.0.0",
	"autoload": {
		"classmap": [
			"inc/"
		]
	},
	"autoload-dev": {
		"classmap": [
			"tests/"
		]
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true,
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"scripts": {
		"phpcs": "phpcs inc/ cl-plugin-weather-widget.php --extensions=php",
		"phpcbf": "phpcbf inc/ cl-plugin-weather-widget.php --extensions=php",
		"test": "phpunit",
		"install-tests": [
			"chmod +x bin/local-mysql-socket.sh",
			"bash -lc 'SOCK=\"$(bin/local-mysql-socket.sh)\"; bash -x bin/install-wp-tests.sh wordpress_test root root \"$SOCK\" latest'"
		]
	},
	"require-dev": {
		"doctrine/instantiator": "^1",
		"phpunit/phpunit": "^9",
		"wp-coding-standards/wpcs": "*",
		"yoast/phpunit-polyfills": "^4.0"
	}
}
